{
    "version": 6,
    "configurePresets": [
        {
            "name": "linux-debug-asan",
            "hidden": false,
            "cacheVariables": {
                "CMAKE_CXX_FLAGS": "-fmax-errors=1 -Wall -Wextra -O1 -g -fno-omit-frame-pointer -fsanitize=address",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address",
                "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=address",
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ]
}